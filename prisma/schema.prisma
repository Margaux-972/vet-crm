generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        Int      @id @default(autoincrement())
  civility  String
  firstName String
  lastName  String
  email     String   @unique
  phone     String

  pet   Pet[]
}

model Pet {
  id       Int    @id @default(autoincrement())
  name     String
  age      Int
  size     Float
  weight   Float
  species  String

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])
}